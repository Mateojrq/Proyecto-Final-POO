<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox maxWidth="480" spacing="10" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.ProfesorController">
    <padding>
        <Insets bottom="10" left="10" right="10" top="10"/>
    </padding>

    <Label styleClass="titulo-seccion" text="Mi Perfil"/>

    <VBox spacing="4">
        <Label text="Correo (no editable)"/>
        <Label fx:id="lblCorreo" styleClass="dato-reporte"/>
    </VBox>

    <VBox spacing="4">
        <Label text="Nombres"/>
        <TextField fx:id="txtNombres"/>
    </VBox>

    <VBox spacing="4">
        <Label text="Apellidos"/>
        <TextField fx:id="txtApellidos"/>
    </VBox>

    <VBox spacing="4">
        <Label text="Especialidad"/>
        <TextField fx:id="txtEspecialidad"/>
    </VBox>

    <VBox spacing="4">
        <Label text="Nueva contrasena (opcional, min. 6 caracteres)"/>
        <PasswordField fx:id="txtNuevaContrasena"/>
    </VBox>

    <Button onAction="#guardarCambios" styleClass="boton-primario" text="Guardar cambios"/>
</VBox>
