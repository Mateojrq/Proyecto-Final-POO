<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="12" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.EntregaController">

    <Label styleClass="titulo-seccion" text="Entregas"/>
    <Label fx:id="lblModoSoloLectura" managed="false" styleClass="aviso-solo-lectura"
           text="Modo de solo lectura: consulta de entregas." visible="false"/>

    <TitledPane collapsible="false" text="Formulario">
        <VBox spacing="8">
            <padding>
                <Insets bottom="10" left="10" right="10" top="10"/>
            </padding>
            <HBox alignment="CENTER_LEFT" spacing="10">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Tarea"/>
                    <ComboBox fx:id="cbTarea" maxWidth="Infinity"/>
                </VBox>
                <VBox spacing="4">
                    <Label text="Archivo"/>
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Button fx:id="btnSeleccionarArchivo" onAction="#seleccionarArchivo" text="Seleccionar"/>
                        <Label fx:id="lblArchivo" text="(sin archivo)"/>
                    </HBox>
                </VBox>
            </HBox>
            <HBox spacing="10">
                <VBox spacing="4">
                    <Label text="Calificacion (0-20)"/>
                    <TextField fx:id="txtCalificacion" prefWidth="120"/>
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Comentario"/>
                    <TextArea fx:id="txtComentario" prefRowCount="2" wrapText="true"/>
                </VBox>
            </HBox>
            <HBox spacing="10">
                <Button fx:id="btnGuardar" onAction="#guardar" styleClass="boton-primario" text="Guardar"/>
                <Button fx:id="btnActualizar" onAction="#actualizar" text="Actualizar"/>
                <Button fx:id="btnEliminar" onAction="#eliminar" styleClass="boton-peligro" text="Eliminar"/>
                <Button fx:id="btnLimpiar" onAction="#limpiar" text="Limpiar"/>
                <Button fx:id="btnDescargar" onAction="#descargarArchivo" text="Descargar archivo"/>
            </HBox>
        </VBox>
    </TitledPane>

    <TableView fx:id="tabla" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colTarea" prefWidth="200" text="Tarea"/>
            <TableColumn fx:id="colEstudiante" prefWidth="160" text="Estudiante"/>
            <TableColumn fx:id="colFecha" prefWidth="140" text="Fecha entrega"/>
            <TableColumn fx:id="colEstado" prefWidth="110" text="Estado"/>
            <TableColumn fx:id="colCalificacion" prefWidth="100" text="Nota"/>
        </columns>
    </TableView>
</VBox>
